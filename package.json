{
  "name": "local-assist",
  "version": "0.1.0",
  "description": "Local AI assistant desktop app",
  "main": "out/main/index.js",
  "author": "trey",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"backend,electron\" --prefix-colors \"cyan,yellow\" --kill-others \"npm run dev:backend\" \"npm run dev:electron\"",
    "dev:backend": ".venv/bin/python -m uvicorn src.backend.main:app --reload --host 127.0.0.1 --port 8000",
    "dev:electron": "ELECTRON_RUN_AS_NODE= electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "@electron-toolkit/preload": "^3.0.1",
    "antd": "^5.22.6",
    "highlight.js": "^11.11.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "uuid": "^14.0.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^20.17.10",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2"
  }
}
